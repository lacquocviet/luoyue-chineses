ssrRenderStyle","_ssrRenderComponent","_unref","_push","_parent","_createVNode"],"sources":["../../../../components/home/CourseCard.vue","../../../../components/home/CourseGrid.vue"],"sourcesContent":["<template>\n  <div class=\"course-card\">\n    <!-- Top Block with emoji -->\n    <div class=\"course-top-block\">\n      <div class=\"course-emoji-wrap\">\n        <span class=\"course-emoji\">{{ course.emoji }}</span>\n      </div>\n      <div class=\"course-badge\" :style=\"{ background: course.color + '20', color: course.color }\">\n        {{ course.level }}\n      </div>\n    </div>\n\n    <!-- Content -->\n    <div class=\"course-body\">\n      <h3 class=\"course-title\">{{ course.title }}</h3>\n      <p class=\"course-desc\">{{ course.desc }}</p>\n\n      <!-- Meta info -->\n      <div class=\"course-meta\">\n        <div class=\"course-meta-item\">\n          <Clock :size=\"14\" />\n          <span>{{ course.duration }}</span>\n        </div>\n        <div class=\"course-meta-item\">\n          <BookOpen :size=\"14\" />\n          <span>{{ course.sessions }}</span>\n        </div>\n      </div>\n\n      <!-- Price + CTA -->\n      <div class=\"course-footer\">\n        <div class=\"course-price\">{{ course.price }}</div>\n        <NuxtLink :to=\"`/khoa-hoc/${course.slug}`\" class=\"btn btn-primary course-btn\">\n          Xem chi tiết\n          <ArrowRight :size=\"16\" />\n        </NuxtLink>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { Clock, BookOpen, ArrowRight } from '@lucide/vue'\n\ndefineProps<{\n  course: {\n    slug: string\n    level: string\n    title: string\n    desc: string\n    duration: string\n    sessions: string\n    price: string\n    color: string\n    emoji: string\n  }\n}>()\n</script>\n\n<style scoped>\n/* Glassmorphism Card Style with 3D Water effect */\n.course-card {\n  display: flex;\n  flex-direction: column;\n  background: rgba(255, 255, 255, 0.45);\n  backdrop-filter: blur(15px);\n  -webkit-backdrop-filter: blur(15px);\n  border: 1px solid rgba(255, 255, 255, 0.65);\n  border-radius: 24px;\n  overflow: hidden;\n  box-shadow: \n    0 8px 32px rgba(31, 38, 135, 0.05),\n    inset 0 4px 4px rgba(255, 255, 255, 0.3),\n    inset 0 -4px 6px rgba(0, 0, 0, 0.02);\n  transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);\n}\n\n.course-card:hover {\n  transform: translateY(-8px) scale(1.02);\n  background: rgba(255, 255, 255, 0.65);\n  border-color: rgba(46, 134, 222, 0.35);\n  box-shadow: \n    0 20px 40px rgba(46, 134, 222, 0.08),\n    inset 0 4px 4px rgba(255, 255, 255, 0.4),\n    inset 0 -4px 6px rgba(0, 0, 0, 0.01);\n}\n\n.course-top-block {\n  padding: 28px 28px 10px;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.course-emoji-wrap {\n  width: 56px;\n  height: 56px;\n  background: white;\n  border-radius: 16px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 4px 10px rgba(0,0,0,0.03);\n}\n\n.course-emoji {\n  font-size: 1.8rem;\n  line-height: 1;\n}\n\n.course-badge {\n  font-size: 0.8rem;\n  font-weight: 700;\n  padding: 6px 12px;\n  border-radius: 12px;\n}\n\n.course-body {\n  padding: 16px 28px 28px;\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n  flex: 1;\n}\n\n.course-title {\n  font-size: 1.25rem;\n  font-weight: 800;\n  color: var(--color-ink);\n}\n\n.course-desc {\n  font-size: 0.9rem;\n  color: var(--color-muted);\n  line-height: 1.6;\n  flex: 1;\n}\n\n.course-meta {\n  display: flex;\n  gap: 16px;\n}\n\n.course-meta-item {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  font-size: 0.825rem;\n  color: var(--color-muted);\n  font-weight: 500;\n}\n\n.course-footer {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  border-top: 1px solid rgba(0,0,0,0.06);\n  padding-top: 20px;\n  margin-top: 4px;\n}\n\n.course-price {\n  font-size: 1.2rem;\n  font-weight: 800;\n  color: var(--color-primary-dark);\n}\n\n.course-btn {\n  padding: 10px 18px;\n  font-size: 0.85rem;\n}\n</style>\n","<template>\n  <section class=\"section courses-section-glass\">\n    <!-- Background decorations for glass effect -->\n    <div class=\"glass-bg-deco glass-deco-1\" />\n    <div class=\"glass-bg-deco glass-deco-2\" />\n\n    <div class=\"container relative-z\">\n      <!-- Header -->\n      <div class=\"section-header reveal\">\n        <div class=\"badge\">📚 Chương trình học</div>\n        <h2 class=\"section-title\">Khóa học <span class=\"text-primary\">nổi bật</span></h2>\n        <div class=\"divider\" />\n        <p class=\"section-subtitle\">\n          Từ người mới bắt đầu đến trình độ cao cấp — chúng tôi có khóa học phù hợp với mọi nhu cầu của bạn.\n        </p>\n      </div>\n\n      <!-- Grid displaying 6 specified courses -->\n      <div class=\"courses-grid\">\n        <CourseCard\n          v-for=\"(course, i) in featuredCourses\"\n          :key=\"course.slug\"\n          :course=\"course\"\n          :style=\"{ transitionDelay: `${i * 60}ms` }\"\n          class=\"reveal\"\n        />\n      </div>\n    </div>\n  </section>\n</template>\n\n<script setup lang=\"ts\">\nconst featuredCourses = [\n  {\n    slug: 'hsk-1',\n    level: 'HSK 1',\n    title: 'Khóa học HSK 1',\n    desc: 'Dành cho người mới bắt đầu làm quen với tiếng Trung.',\n    duration: '2 tháng',\n    sessions: '24 buổi',\n    price: '2.800.000₫',\n    color: '#4ECDC4',\n    emoji: '🌱',\n  },\n  {\n    slug: 'hsk-2',\n    level: 'HSK 2',\n    title: 'Khóa học HSK 2',\n    desc: 'Mở rộng vốn từ và giao tiếp trong các tình huống hằng ngày.',\n    duration: '2 tháng',\n    sessions: '24 buổi',\n    price: '2.800.000₫',\n    color: '#45B7D1',\n    emoji: '🌿',\n  },\n  {\n    slug: 'hsk-3',\n    level: 'HSK 3',\n    title: 'Khóa học HSK 3',\n    desc: 'Xây dựng nền tảng ngữ pháp và nâng cao khả năng giao tiếp.',\n    duration: '3 tháng',\n    sessions: '36 buổi',\n    price: '3.500.000₫',\n    color: '#3498db',\n    emoji: '🌳',\n  },\n  {\n    slug: 'hsk-4',\n    level: 'HSK 4',\n    title: 'Khóa học HSK 4',\n    desc: 'Tăng khả năng sử dụng tiếng Trung trong học tập và công việc.',\n    duration: '3 tháng',\n    sessions: '36 buổi',\n    price: '3.500.000₫',\n    color: '#9b59b6',\n    emoji: '🎓',\n  },\n  {\n    slug: 'business-chinese',\n    level: 'Thương mại',\n    title: 'Business Chinese',\n    desc: 'Dành cho người đi làm, tập trung giao tiếp thương mại, đàm phán, xuất nhập khẩu.',\n    duration: '3 tháng',\n    sessions: '36 buổi',\n    price: '4.000.000₫',\n    color: '#e67e22',\n    emoji: '💼',\n  },\n  {\n    slug: 'giao-tiep',\n    level: 'Giao tiếp',\n    title: 'Tiếng Trung Giao tiếp',\n    desc: 'Chương trình chú trọng hoàn toàn vào phản xạ nói, phát âm chuẩn tự nhiên như người bản xứ.',\n    duration: '2.5 tháng',\n    sessions: '30 buổi',\n    price: '2.800.000₫',\n    color: '#e74c3c',\n    emoji: '🗣️',\n  },\n]\n\n// Scroll reveal is handled globally in app.vue\n</script>\n\n<style scoped>\n.courses-section-glass {\n  position: relative;\n  background: linear-gradient(180deg, #dce6f5 0%, #e8f0fe 100%);\n  overflow: hidden;\n}\n\n.glass-bg-deco {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(80px);\n  z-index: 1;\n  opacity: 0.4;\n}\n\n.glass-deco-1 {\n  width: 400px;\n  height: 400px;\n  background: rgba(46, 134, 222, 0.15);\n  top: 20%;\n  right: -100px;\n}\n\n.glass-deco-2 {\n  width: 300px;\n  height: 300px;\n  background: rgba(255, 233, 168, 0.2);\n  bottom: 10%;\n  left: -50px;\n}\n\n.relative-z {\n  position: relative;\n  z-index: 2;\n}\n\n.section-header {\n  text-align: center;\n  margin-bottom: 56px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n.section-header .section-title {\n  margin-top: 12px;\n}\n\n.section-header .divider {\n  margin: 16px auto 0;\n}\n\n.section-header .section-subtitle {\n  text-align: center;\n  margin-top: 16px;\n}\n\n.courses-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 32px;\n}\n\n@media (max-width: 1024px) {\n  .courses-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }\n}\n\n@media (max-width: 768px) {\n  .courses-grid { grid-template-columns: 1fr; }\n}\n</style>\n"],"version":3}