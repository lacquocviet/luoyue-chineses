{"file":"index-DuPqQ2wq.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;AACW,YAAA,WAAAA,eAAAC,WAAA,EAAA,OAAM,UAAM,MAAA,CAAA,CAAA,omCAAA;;QAwCH,IAAG;AAAA,QAAW,OAAM;AAAA,MAAA;yBAA9B,CAGW,GAAAC,QAAAC,UAAA,aAAA;;AAFED,mBAAAE,mBAAAC,MAAA,QAAA,GAAA,EAAA,MAAM,MAAE,MAAAF,UAAA,QAAA,CAAA;;;;cAAnBG,YAAuBD,MAAA,QAAA,GAAA,EAAZ,MAAM,IAAE;AAAA,8BAAI,eAEzB;AAAA,YAAA;AAAA;;;;AAOK,YAAA,+GAAAE,cAAA,OAAA,UAA0B,CAAA,2PAAA;AAOrB,YAAAH,mBAAAC,MAAA,WAAA,GAAA,EAAA,MAAM,GAAA,GAAE,MAAA,OAAA,CAAA;;;;;;;;;;;;;;;;;;ACzDjB,YAAA,WAAAL,eAAAC,WAAA,EAAA,OAAM,2BAAuB,MAAA,CAAA,CAAA,okCAAA;;QAwBtB,IAAG;AAAA,QAAc,OAAM;AAAA,MAAA;yBAAjC,CAAkG,GAAAC,QAAAC,UAAA,aAAA;;;;;8BAArC,4BAA0B;AAAA,YAAA;AAAA;;;;gFAIpD,EAAA,oBAAA,QAAA,CAAgC,+EAE5DI,cAAA,OAAAC,YAAwB;;;;;;;;;;;;;;;ACMvC,UAAM,WAAW;AAAA,MACf;AAAA,QACE,OAAO;AAAA,QACP,OAAO;AAAA,QACP,MAAM;AAAA,MAAA;AAAA,MAER;AAAA,QACE,OAAO;AAAA,QACP,OAAO;AAAA,QACP,MAAM;AAAA,MAAA;AAAA,MAER;AAAA,QACE,OAAO;AAAA,QACP,OAAO;AAAA,QACP,MAAM;AAAA,MAAA;AAAA,MAER;AAAA,QACE,OAAO;AAAA,QACP,OAAO;AAAA,QACP,MAAM;AAAA,MAAA;AAAA,MAER;AAAA,QACE,OAAO;AAAA,QACP,OAAO;AAAA,QACP,MAAM;AAAA,MAAA;AAAA,MAER;AAAA,QACE,OAAO;AAAA,QACP,OAAO;AAAA,QACP,MAAM;AAAA,MAAA;AAAA,IACR;;;QAlES,IAAG;AAAA,QAAS,OAAM;AAAA,MAAA;oBAmBC,UAAQ,CAApB,MAAM,MAAC;0FAGe,IAAC,EAAA,MAAA,8GAGGC,eAAA,KAAK,KAAK,4DAEdA,eAAA,KAAK,KAAK,kDACZA,eAAA,KAAK,IAAI;;;;;;;;;;;;;;;;;ACN/C,YAAQ;AAAA,MACN,OAAO;AAAA,MACP,MAAM;AAAA,QACJ;AAAA,UACE,MAAM;AAAA,UACN,SAAS;AAAA,QAAA;AAAA,QAEX,EAAE,UAAU,YAAY,SAAS,wBAAA;AAAA,QACjC,EAAE,UAAU,kBAAkB,SAAS,6HAAA;AAAA,MAA6H;AAAA,IACtK,CACD;;;;;;;;;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_ssrRenderComponent","_unref","_createVNode","_ssrRenderAttr","_imports_0","_ssrInterpolate"],"sources":["../../../../components/home/HeroSection.vue","../../../../components/home/IntroSection.vue","../../../../components/home/WhyChooseUs.vue","../../../../pages/index.vue"],"sourcesContent":["<template>\n  <section class=\"hero\">\n    <!-- Background with overlay -->\n    <div class=\"hero-bg\">\n      <div class=\"hero-overlay\" />\n      <!-- Animated background shapes -->\n      <div class=\"hero-shape hero-shape-1\" />\n      <div class=\"hero-shape hero-shape-2\" />\n      <div class=\"hero-shape hero-shape-3\" />\n    </div>\n\n    <div class=\"container hero-grid\">\n      <!-- Left column: Content -->\n      <div class=\"hero-content\">\n        <!-- Badges row -->\n        <div class=\"hero-badges reveal\">\n          <span class=\"badge\">\n            <span>✓</span> Online & Offline\n          </span>\n          <span class=\"badge\">\n            <span>✓</span> HSK 1–6\n          </span>\n          <span class=\"badge\">\n            <span>✓</span> Business Chinese\n          </span>\n        </div>\n\n        <!-- H1 -->\n        <h1 class=\"hero-title reveal\">\n          LUOYUE CHINESE<br />\n          <span class=\"hero-title-main\">Học tiếng Trung thông minh,</span><br />\n          <span class=\"hero-title-accent\">chinh phục HSK dễ dàng.</span>\n        </h1>\n\n        <!-- Subtitle -->\n        <p class=\"hero-subtitle reveal\">\n          Lộ trình cá nhân hóa • Giáo viên tận tâm • Cam kết đồng hành\n        </p>\n\n        <!-- CTA Buttons -->\n        <div class=\"hero-ctas reveal\">\n          <NuxtLink to=\"/lien-he\" class=\"btn btn-primary hero-btn-main\">\n            <BookOpen :size=\"20\" />\n            Đăng ký học\n          </NuxtLink>\n        </div>\n      </div>\n\n      <!-- Right column: Banner -->\n      <div class=\"hero-banner reveal\">\n        <div class=\"banner-wrapper\">\n          <img src=\"/sources/banner.jpeg\" alt=\"Luoyue Chinese Banner\" class=\"banner-img\" onerror=\"this.src='/logo.png'; this.style.objectFit='contain'; this.style.padding='20px'\" />\n        </div>\n      </div>\n    </div>\n\n    <!-- Scroll down indicator -->\n    <a href=\"#stats\" class=\"hero-scroll\">\n      <ChevronDown :size=\"24\" />\n    </a>\n  </section>\n</template>\n\n<script setup lang=\"ts\">\nimport { BookOpen, ChevronDown } from '@lucide/vue'\n</script>\n\n<style scoped>\n.hero {\n  position: relative;\n  min-height: 100vh;\n  display: flex;\n  align-items: center;\n  overflow: hidden;\n  padding-top: 80px;\n  padding-bottom: 60px;\n}\n\n.hero-bg {\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(135deg, #0f2d6b 0%, #1B4F91 35%, #2E86DE 70%, #4ea3f0 100%);\n}\n\n.hero-overlay {\n  position: absolute;\n  inset: 0;\n  background: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n}\n\n.hero-shape {\n  position: absolute;\n  border-radius: 50%;\n  opacity: 0.08;\n  animation: float 8s ease-in-out infinite;\n}\n\n.hero-shape-1 {\n  width: 600px;\n  height: 600px;\n  background: var(--color-accent-dark);\n  top: -150px;\n  right: -100px;\n  animation-delay: 0s;\n}\n\n.hero-shape-2 {\n  width: 400px;\n  height: 400px;\n  background: white;\n  bottom: -80px;\n  left: -80px;\n  animation-delay: 3s;\n}\n\n.hero-shape-3 {\n  width: 250px;\n  height: 250px;\n  background: var(--color-accent);\n  top: 40%;\n  right: 15%;\n  animation-delay: 5s;\n}\n\n@keyframes float {\n  0%, 100% { transform: translateY(0) rotate(0deg); }\n  33% { transform: translateY(-20px) rotate(5deg); }\n  66% { transform: translateY(10px) rotate(-3deg); }\n}\n\n.hero-grid {\n  position: relative;\n  z-index: 1;\n  display: grid;\n  grid-template-columns: 1.2fr 0.8fr;\n  gap: 40px;\n  align-items: center;\n  width: 100%;\n}\n\n.hero-content {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n  gap: 24px;\n}\n\n.hero-badges {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n.hero-badges .badge {\n  background: rgba(255, 233, 168, 0.15);\n  border: 1px solid rgba(255, 233, 168, 0.4);\n  color: var(--color-accent);\n  backdrop-filter: blur(8px);\n  padding: 6px 14px;\n  border-radius: 20px;\n  font-size: 0.85rem;\n  font-weight: 500;\n}\n\n.hero-title {\n  font-size: clamp(2rem, 4vw, 3.25rem);\n  font-weight: 900;\n  color: white;\n  line-height: 1.2;\n  letter-spacing: -0.01em;\n}\n\n.hero-title-main {\n  font-size: 0.85em;\n  font-weight: 800;\n}\n\n.hero-title-accent {\n  color: var(--color-accent-dark);\n}\n\n.hero-subtitle {\n  font-size: 1.15rem;\n  color: rgba(255, 255, 255, 0.9);\n  font-weight: 500;\n  border-left: 3px solid var(--color-accent-dark);\n  padding-left: 12px;\n}\n\n.hero-ctas {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.hero-btn-main {\n  padding: 16px 36px;\n  font-size: 1.05rem;\n  font-weight: 700;\n  box-shadow: 0 8px 32px rgba(255, 233, 168, 0.2);\n}\n\n.hero-banner {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n}\n\n.banner-wrapper {\n  width: 100%;\n  max-width: 450px;\n  aspect-ratio: 4/3;\n  border-radius: 24px;\n  overflow: hidden;\n  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);\n  border: 4px solid rgba(255, 255, 255, 0.1);\n  background: rgba(255, 255, 255, 0.05);\n  backdrop-filter: blur(10px);\n}\n\n.banner-img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n\n.hero-scroll {\n  position: absolute;\n  bottom: 24px;\n  left: 50%;\n  transform: translateX(-50%);\n  color: rgba(255, 255, 255, 0.6);\n  animation: bounce 2s ease-in-out infinite;\n  z-index: 2;\n}\n\n@keyframes bounce {\n  0%, 100% { transform: translateX(-50%) translateY(0); }\n  50% { transform: translateX(-50%) translateY(8px); }\n}\n\n@media (max-width: 1024px) {\n  .hero-grid {\n    grid-template-columns: 1fr;\n    text-align: center;\n    gap: 48px;\n    padding-top: 40px;\n  }\n  .hero-content {\n    align-items: center;\n  }\n  .hero-subtitle {\n    border-left: none;\n    padding-left: 0;\n  }\n}\n</style>\n","<template>\n  <section class=\"intro-section section\">\n    <div class=\"container intro-grid\">\n      <!-- Left: Introduction Text -->\n      <div class=\"intro-content reveal\">\n        <h2 class=\"section-title text-left\">Giới thiệu <span class=\"text-primary\">Luoyue Chinese</span></h2>\n        <p class=\"about-p\">\n          Luoyue Chinese được thành lập với mong muốn giúp người Việt học tiếng Trung một cách bài bản, dễ hiểu và ứng dụng thực tế. Chúng tôi tin rằng học ngôn ngữ không chỉ để thi mà còn để giao tiếp và mở rộng cơ hội nghề nghiệp.\n        </p>\n        <div class=\"intro-features\">\n          <div class=\"intro-feat-item\">\n            <span class=\"feat-icon\">🎯</span>\n            <div>\n              <h4>Học thông minh, nhớ lâu hơn</h4>\n              <p>Phương pháp độc quyền rút ngắn 30% thời gian học chữ Hán.</p>\n            </div>\n          </div>\n          <div class=\"intro-feat-item\">\n            <span class=\"feat-icon\">🗣️</span>\n            <div>\n              <h4>Phản xạ giao tiếp tự nhiên</h4>\n              <p>Chú trọng tối đa việc luyện nói và chỉnh phát âm chuẩn ngay từ đầu.</p>\n            </div>\n          </div>\n        </div>\n        <NuxtLink to=\"/gioi-thieu\" class=\"btn btn-primary intro-btn\">Tìm hiểu thêm về chúng tôi</NuxtLink>\n      </div>\n\n      <!-- Right: Class Image -->\n      <div class=\"intro-image-wrap reveal\" style=\"transition-delay: 150ms;\">\n        <div class=\"image-border-decoration\">\n          <img src=\"/sources/class.png\" alt=\"Lớp học tại Luoyue Chinese\" class=\"intro-img\" onerror=\"this.src='/logo.png'; this.style.objectFit='contain'; this.style.padding='40px'\" />\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n\n<script setup lang=\"ts\">\n// Scroll reveal is handled globally in app.vue — no local observer needed.\n</script>\n\n<style scoped>\n.intro-section {\n  background: white;\n  overflow: hidden;\n}\n\n.intro-grid {\n  display: grid;\n  grid-template-columns: 1.1fr 0.9fr;\n  gap: 60px;\n  align-items: center;\n}\n\n.intro-content {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n  gap: 20px;\n}\n\n.text-left {\n  text-align: left;\n  margin-bottom: 0;\n}\n\n.about-p {\n  font-size: 1.05rem;\n  line-height: 1.7;\n  color: var(--color-ink);\n  opacity: 0.85;\n}\n\n.intro-features {\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n  margin: 10px 0;\n}\n\n.intro-feat-item {\n  display: flex;\n  gap: 16px;\n  align-items: flex-start;\n}\n\n.feat-icon {\n  font-size: 1.5rem;\n  background: var(--color-accent);\n  padding: 8px;\n  border-radius: 12px;\n  line-height: 1;\n}\n\n.intro-feat-item h4 {\n  font-size: 1rem;\n  font-weight: 700;\n  color: var(--color-ink);\n  margin-bottom: 4px;\n}\n\n.intro-feat-item p {\n  font-size: 0.875rem;\n  color: var(--color-muted);\n  line-height: 1.5;\n}\n\n.intro-btn {\n  margin-top: 10px;\n}\n\n.intro-image-wrap {\n  display: flex;\n  justify-content: center;\n}\n\n.image-border-decoration {\n  position: relative;\n  border-radius: 24px;\n  overflow: hidden;\n  box-shadow: 0 15px 40px rgba(0,0,0,0.1);\n  background: var(--color-accent);\n  aspect-ratio: 4/3;\n  width: 100%;\n  max-width: 480px;\n}\n\n.intro-img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 0.5s ease;\n}\n\n.intro-img:hover {\n  transform: scale(1.05);\n}\n\n@media (max-width: 992px) {\n  .intro-grid {\n    grid-template-columns: 1fr;\n    gap: 40px;\n  }\n  .intro-image-wrap {\n    order: -1;\n  }\n}\n</style>\n","<template>\n  <section id=\"why-us\" class=\"section why-us-glass\">\n    <!-- Background elements to enhance glass effect -->\n    <div class=\"glass-bg-deco glass-deco-1\" />\n    <div class=\"glass-bg-deco glass-deco-2\" />\n\n    <div class=\"container relative-z\">\n      <!-- Header -->\n      <div class=\"section-header reveal\">\n        <div class=\"badge\">✨ Điểm khác biệt</div>\n        <h2 class=\"section-title\">Vì sao chọn <span class=\"text-primary\">Luoyue?</span></h2>\n        <div class=\"divider\" />\n        <p class=\"section-subtitle\">\n          Chúng tôi mang đến trải nghiệm học tiếng Trung toàn diện, hiệu quả và thân thiện nhất.\n        </p>\n      </div>\n\n      <!-- Features grid -->\n      <div class=\"why-grid\">\n        <div\n          v-for=\"(item, i) in features\"\n          :key=\"i\"\n          class=\"why-card reveal\"\n          :style=\"{ transitionDelay: `${i * 80}ms` }\"\n        >\n          <div class=\"why-icon-wrap\">\n            <span class=\"why-icon-emoji\">{{ item.emoji }}</span>\n          </div>\n          <h3 class=\"why-card-title\">{{ item.title }}</h3>\n          <p class=\"why-card-desc\">{{ item.desc }}</p>\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n\n<script setup lang=\"ts\">\nconst features = [\n  {\n    emoji: '🎯',\n    title: 'Lộ trình cá nhân hóa',\n    desc: 'Lộ trình thiết kế riêng biệt phù hợp với xuất phát điểm, năng lực tiếp thu và mục tiêu của từng học viên.',\n  },\n  {\n    emoji: '👩‍🏫',\n    title: 'Giáo viên nhiều kinh nghiệm',\n    desc: 'Đội ngũ giảng viên sở hữu chứng chỉ giảng dạy quốc tế, phát âm chuẩn và có nhiều năm kinh nghiệm đứng lớp.',\n  },\n  {\n    emoji: '📚',\n    title: 'Giáo trình cập nhật',\n    desc: 'Học liệu luôn được tối ưu và cập nhật mới nhất theo chuẩn HSK 9 cấp quốc tế mới.',\n  },\n  {\n    emoji: '🌏',\n    title: 'Học Online & Offline',\n    desc: 'Mô hình kết hợp linh hoạt trực tuyến và trực tiếp, hỗ trợ ghi lại buổi học để học viên ôn tập mọi lúc.',\n  },\n  {\n    emoji: '📈',\n    title: 'Theo dõi tiến độ học tập',\n    desc: 'Hệ thống báo cáo học tập định kỳ và thi thử sát sao giúp học viên nhìn rõ sự tiến bộ từng tuần.',\n  },\n  {\n    emoji: '🏆',\n    title: 'Cam kết đồng hành',\n    desc: 'Đồng hành chặt chẽ 24/7 và cam kết hỗ trợ học lại hoàn toàn miễn phí nếu không đạt kết quả đầu ra.',\n  },\n]\n</script>\n\n<style scoped>\n.why-us-glass {\n  position: relative;\n  background: linear-gradient(180deg, #f8faff 0%, #edf2fc 100%);\n  overflow: hidden;\n}\n\n.glass-bg-deco {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(80px);\n  z-index: 1;\n  opacity: 0.5;\n}\n\n.glass-deco-1 {\n  width: 300px;\n  height: 300px;\n  background: rgba(46, 134, 222, 0.2);\n  top: 10%;\n  left: -50px;\n}\n\n.glass-deco-2 {\n  width: 400px;\n  height: 400px;\n  background: rgba(255, 233, 168, 0.25);\n  bottom: 5%;\n  right: -100px;\n}\n\n.relative-z {\n  position: relative;\n  z-index: 2;\n}\n\n.section-header {\n  text-align: center;\n  margin-bottom: 56px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n.section-header .section-title {\n  margin-top: 12px;\n}\n\n.section-header .divider {\n  margin: 16px auto 0;\n}\n\n.section-header .section-subtitle {\n  text-align: center;\n  margin-top: 16px;\n}\n\n.why-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 28px;\n}\n\n/* Glassmorphism 3D Water Effect Card */\n.why-card {\n  background: rgba(255, 255, 255, 0.45);\n  backdrop-filter: blur(15px);\n  -webkit-backdrop-filter: blur(15px);\n  border: 1px solid rgba(255, 255, 255, 0.65);\n  border-radius: 20px;\n  padding: 36px 30px;\n  box-shadow: \n    0 8px 32px rgba(31, 38, 135, 0.05),\n    inset 0 4px 4px rgba(255, 255, 255, 0.3),\n    inset 0 -4px 6px rgba(0, 0, 0, 0.02);\n  transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.why-card:hover {\n  transform: translateY(-8px) scale(1.02);\n  background: rgba(255, 255, 255, 0.65);\n  border-color: rgba(46, 134, 222, 0.35);\n  box-shadow: \n    0 20px 40px rgba(46, 134, 222, 0.08),\n    inset 0 4px 4px rgba(255, 255, 255, 0.4),\n    inset 0 -4px 6px rgba(0, 0, 0, 0.01);\n}\n\n.why-icon-wrap {\n  width: 56px;\n  height: 56px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: rgba(255, 255, 255, 0.7);\n  border-radius: 16px;\n  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.03);\n}\n\n.why-icon-emoji {\n  font-size: 1.75rem;\n}\n\n.why-card-title {\n  font-size: 1.15rem;\n  font-weight: 700;\n  color: var(--color-ink);\n}\n\n.why-card-desc {\n  font-size: 0.9rem;\n  color: var(--color-muted);\n  line-height: 1.65;\n}\n\n@media (max-width: 1024px) {\n  .why-grid { grid-template-columns: repeat(2, 1fr); }\n}\n\n@media (max-width: 640px) {\n  .why-grid { grid-template-columns: 1fr; }\n}\n</style>\n","<template>\n  <main>\n    <!-- 1. Hero Section -->\n    <HeroSection />\n\n    <!-- 2. Stats Counter -->\n    <StatsCounter />\n\n    <!-- 3. Introduction Section -->\n    <IntroSection />\n\n    <!-- 4. Why Choose Us -->\n    <WhyChooseUs />\n\n    <!-- 5. Course Grid -->\n    <CourseGrid />\n\n    <!-- 6. CTA Banner -->\n    <CtaBanner />\n  </main>\n</template>\n\n<script setup lang=\"ts\">\nuseHead({\n  title: 'Luoyue Chinese | Trung tâm tiếng Trung 雒越中文 — HSK, Giao tiếp, Thiếu nhi',\n  meta: [\n    {\n      name: 'description',\n      content: 'Luoyue Chinese – Trung tâm đào tạo tiếng Trung hàng đầu tại Việt Nam. Luyện HSK 1–6, tiếng Trung giao tiếp, thiếu nhi, Business Chinese. Cam kết đầu ra, lớp nhỏ, giảng viên giàu kinh nghiệm.',\n    },\n    { property: 'og:title', content: 'Luoyue Chinese | 雒越中文' },\n    { property: 'og:description', content: 'Chinh phục tiếng Trung cùng đội ngũ giảng viên giàu kinh nghiệm. HSK 1–6, giao tiếp, thiếu nhi, business. 1.200+ học viên.' },\n  ],\n})\n\n// Scroll reveal is handled globally in app.vue via IntersectionObserver.\n// No local observer needed — it would conflict with the global one and\n// cause the menu navigation bug (content not displaying after click).\n</script>\n"],"version":3}